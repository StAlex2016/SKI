# ─────────────────────────────────────────────────────────────────────────────
# STAGING environment file — /home/ubuntu/ski-mvp-bot/.env.staging
# Loaded by skibot-staging.service via EnvironmentFile=
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=staging

# ── Telegram ───────────────────────────────────────────────────────────────────
# MUST be a DIFFERENT bot than prod — long polling on same token will conflict.
# Create via @BotFather, e.g. @alpineski_staging_bot.
TELEGRAM_BOT_TOKEN=<STAGING_BOT_TOKEN>

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# SEPARATE key so you can set a hard spend-limit in OpenAI dashboard
# WITHOUT affecting prod. Model is IDENTICAL to prod — no cheap-mode.
OPENAI_API_KEY=<STAGING_OPENAI_KEY>
OPENAI_MODEL=gpt-4.1                  # MUST MATCH PROD

# ── Access ─────────────────────────────────────────────────────────────────────
# REQUIRED: set explicitly so daily-report alerts don't leak to prod owner chat
OWNER_ID=202921941
ALLOWED_USER_IDS=202921941,201955370

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Same cluster, separate database
PG_HOST=localhost
PG_PORT=5432
PG_DB=skibot_staging
PG_USER=skibot_staging
PG_PASSWORD=<STAGING_PG_PASSWORD>

# ── Redis ──────────────────────────────────────────────────────────────────────
# Same Redis server, isolated logical DB index
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1                            # STAGING uses logical DB 1

# ── PostHog ────────────────────────────────────────────────────────────────────
# Option A: separate PostHog project (recommended — clean funnels)
# Option B: same key but rely on auto-injected "env=staging" property filter
POSTHOG_API_KEY=<STAGING_POSTHOG_KEY>
POSTHOG_HOST=https://eu.posthog.com

# ── Filesystem (all under /var/lib/skibot/staging to avoid any cross-env I/O) ──
LOG_DIR=/var/lib/skibot/staging/logs
OUTPUT_DIR=/var/lib/skibot/staging
TMP_DIR=/tmp/skibot_staging
