# ─────────────────────────────────────────────────────────────────────────────
# PROD environment file — /home/ubuntu/ski-mvp-bot/.env.prod
# Loaded by skibot-prod.service via EnvironmentFile=
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=prod

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<PROD_BOT_TOKEN>   # @alpineski_bot (main)

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<PROD_OPENAI_KEY>
OPENAI_MODEL=gpt-4.1                  # SAME AS STAGING — no cheap-mode split

# ── Access ─────────────────────────────────────────────────────────────────────
OWNER_ID=202921941
ALLOWED_USER_IDS=202921941,201955370

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=skibot
PG_USER=skibot
PG_PASSWORD=<PROD_PG_PASSWORD>

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0                            # PROD uses logical DB 0

# ── PostHog ────────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=<PROD_POSTHOG_KEY>
POSTHOG_HOST=https://eu.posthog.com

# ── Filesystem ─────────────────────────────────────────────────────────────────
LOG_DIR=/home/ubuntu/ski-mvp-bot/logs
OUTPUT_DIR=/home/ubuntu/ski-mvp-bot
TMP_DIR=/tmp
